@page "/admin/products"
@rendermode InteractiveServer
@attribute [Authorize(Policy = ShoppingPolicies.CatalogManagement)]

<PageTitle>Product management</PageTitle>

<h1>Product management</h1>

<p>Manage product descriptions, images, pricing, and availability.</p>

<section class="admin-panel">
    <label>
        Product name
        <input @bind="name" />
    </label>
    <label>
        Price
        <input type="number" step="0.01" @bind="price" />
    </label>
    <label>
        Available
        <input type="checkbox" @bind="available" />
    </label>
    <button @onclick="Save">Save draft</button>
</section>

<p>@status</p>

@code {
    private string name = "";
    private decimal price;
    private bool available = true;
    private string status = "";

    private void Save()
    {
        status = $"Draft saved for {name} at GBP {price:0.00}; available: {available}.";
    }
}
